        <mxCell id="p1src3" value="&lt;font style=&quot;font-family:Courier New;font-size:9px&quot;&gt;public static StageConfig s01() {&lt;br&gt;  // &#10112; &#21482;&#24320;&#25918;bash,&lt;br&gt;  // &#29702;&#35299;&#26368;&#21407;&#22987;&#38381;&#29615;&lt;br&gt;  return new StageConfig(&lt;br&gt;    &quot;s01&quot;, false, false, false,&lt;br&gt;    false, false, false,&lt;br&gt;    List.of(baseTools().get(0)),&lt;br&gt;    // &#10113; system prompt&lt;br&gt;    // &#25351;&#31034;Act&#19981;&#35201;&#35299;&#37322;&lt;br&gt;    &quot;You are a coding agent...&quot;&lt;br&gt;  );&lt;br&gt;}&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=9;fontColor=#333333;spacingLeft=5;" vertex="1" parent="1"><mxGeometry x="835" y="533" width="295" height="120" as="geometry" /></mxCell>
