        <mxCell id="p1src1title" value="AgentRuntime.runRepl() - REPL&#20132;&#20114;&#24490;&#29615; (&#31532;97-123&#34892;)" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=10;fontStyle=1;fontColor=#1e3a5f;" vertex="1" parent="1"><mxGeometry x="40" y="515" width="350" height="16" as="geometry" /></mxCell>
        <mxCell id="p1src1" value="&lt;font style=&quot;font-family:Courier New;font-size:9px&quot;&gt;while (true) {                           // &#10102; REPL&#20027;&#24490;&#29615;&lt;br&gt;  String query = scanner.nextLine();    // &#10103; &#35835;&#29992;&#25143;&#36755;&#20837;&lt;br&gt;  history.add(new ChatMessage(&quot;user&quot;,  // &#10104; &#29992;&#25143;&#28040;&#24687;&#20837;&#38431;&lt;br&gt;      query));&lt;br&gt;  agentLoop(history, config);            // &#10105; &#36827;&#20837;Agent&#26680;&#24515;&#24490;&#29615;&lt;br&gt;  // &#25171;&#21360; assistant &#26368;&#32456;&#25991;&#26412;&#22238;&#22797;&lt;br&gt;}&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=9;fontColor=#333333;spacingLeft=5;" vertex="1" parent="1"><mxGeometry x="40" y="533" width="350" height="88" as="geometry" /></mxCell>
