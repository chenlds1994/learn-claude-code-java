        <mxCell id="p1src2" value="&lt;font style=&quot;font-family:Courier New;font-size:9px&quot;&gt;while (true) {                               // &#10106; Agent&#20027;&#24490;&#29615;&lt;br&gt;  var response = client.createMessage(...);   // &#10107; &#35843;&#29992;&#22823;&#27169;&#22411;&lt;br&gt;  messages.add(new ChatMessage(&quot;assistant&quot;, response.content()));&lt;br&gt;  if (!&quot;tool_use&quot;.equals(response.stop_reason()))&lt;br&gt;    return;                                  // &#10108; &#38750;tool_use&#21017;&#32467;&#26463;&lt;br&gt;  String output = switch (toolName) {          // &#10109; &#24037;&#20855;&#20998;&#21457;&lt;br&gt;    case &quot;bash&quot; -&gt; commandTools.runBash(cmd);  // &#10110; &#26412;&#22320;&#25191;&#34892;&lt;br&gt;  };&lt;br&gt;  messages.add(new ChatMessage(&quot;user&quot;, results)); // &#10111; &#32467;&#26524;&#22238;&#27880;&lt;br&gt;}&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=9;fontColor=#333333;spacingLeft=5;" vertex="1" parent="1"><mxGeometry x="415" y="533" width="395" height="120" as="geometry" /></mxCell>
